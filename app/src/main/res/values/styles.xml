<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 沉浸式电视直播主题，继承自 AppCompat 并去除标题栏，设置全屏 -->
    <style name="Theme.DianshijiaLite" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- 保持屏幕常亮 -->
        <item name="android:keepScreenOn">true</item>
    </style>

    <!-- 暗黑高亮风格的更新弹窗主题，与 TV 风格保持一致 -->
    <style name="Theme.DianshijiaLite.Dialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@color/bg_sidebar</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_normal</item>
        <item name="colorAccent">@color/bg_focus</item>
    </style>
</resources>
