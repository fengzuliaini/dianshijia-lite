<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- 全屏 视频渲染容器 -->
    <TextureView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <!-- 侧边栏选择菜单：包含分类列表、频道列表、回看时段列表 -->
    <LinearLayout
        android:id="@+id/layout_sidebar"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@android:color/transparent">

        <!-- 第一列：分类列表 -->
        <ListView
            android:id="@+id/list_categories"
            android:layout_width="140dp"
            android:layout_height="match_parent"
            android:background="@color/bg_sidebar"
            android:divider="@null"
            android:scrollbars="none"
            android:choiceMode="singleChoice" />

        <!-- 第二列：具体频道列表 -->
        <ListView
            android:id="@+id/list_channels"
            android:layout_width="240dp"
            android:layout_height="match_parent"
            android:background="@color/bg_sidebar_sub"
            android:divider="@null"
            android:scrollbars="none"
            android:choiceMode="singleChoice" />

        <!-- 第三列：回看时段列表 (初始隐藏，遥控按右或触屏呼出) -->
        <ListView
            android:id="@+id/list_catchup"
            android:layout_width="180dp"
            android:layout_height="match_parent"
            android:background="#E62C2C2E"
            android:divider="@null"
            android:scrollbars="none"
            android:choiceMode="singleChoice"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 左下角换台及线路提示框 (电视家经典 OSD 样式) -->
    <LinearLayout
        android:id="@+id/layout_info_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|left"
        android:layout_marginLeft="45dp"
        android:layout_marginBottom="90dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="25dp"
        android:paddingRight="25dp"
        android:paddingTop="15dp"
        android:paddingBottom="15dp"
        android:background="@drawable/bg_info_overlay"
        android:visibility="gone">

        <!-- 提示框中的金黄色台号 -->
        <TextView
            android:id="@+id/text_overlay_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textColor="@color/accent_gold"
            android:textStyle="bold"
            android:layout_marginRight="15dp" />

        <!-- 垂直放置频道信息和节目单信息 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 提示框中的频道名与线路 -->
            <TextView
                android:id="@+id/text_overlay_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <!-- 当前节目及结束时间 -->
            <TextView
                android:id="@+id/text_overlay_current_program"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#E0FFFFFF"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <!-- 下一个节目名 -->
            <TextView
                android:id="@+id/text_overlay_next_program"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#A0FFFFFF"
                android:layout_marginTop="2dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- 屏幕中央视频缓冲加载中浮层 -->
    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingLeft="30dp"
        android:paddingRight="30dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:background="@color/bg_overlay">

        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/text_loading_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading_stream"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 数字按键直接换台的巨型提示框 -->
    <LinearLayout
        android:id="@+id/layout_number_input"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:paddingLeft="40dp"
        android:paddingRight="40dp"
        android:paddingTop="25dp"
        android:paddingBottom="25dp"
        android:background="@color/bg_overlay"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_number_input"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="72sp"
            android:textColor="@color/accent_gold"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 底部播放进度控制栏：回看模式下可见 -->
    <LinearLayout
        android:id="@+id/layout_controller"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#E61A1A1A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="15dp"
        android:paddingBottom="15dp"
        android:visibility="gone">

        <!-- 播放/暂停文本按钮 -->
        <TextView
            android:id="@+id/btn_play_pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:text="⏸"
            android:padding="5dp"
            android:focusable="true"
            android:clickable="true" />

        <!-- 当前进度时间 -->
        <TextView
            android:id="@+id/text_time_current"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:text="00:00:00"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp" />

        <!-- 进度条 -->
        <SeekBar
            android:id="@+id/seek_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:focusable="true" />

        <!-- 总时长 -->
        <TextView
            android:id="@+id/text_time_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:text="00:00:00"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp" />

        <!-- 一键返回直播按钮 -->
        <TextView
            android:id="@+id/text_back_to_live"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/accent_gold"
            android:textStyle="bold"
            android:text="返回直播"
            android:background="@drawable/selector_item"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:focusable="true"
            android:clickable="true" />
    </LinearLayout>

</FrameLayout>
